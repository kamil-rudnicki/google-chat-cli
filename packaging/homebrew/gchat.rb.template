class Gchat < Formula
  desc "Script-first Google Chat CLI"
  homepage "https://github.com/<owner>/google-chat-cli"
  version "<version>"
  license "MIT"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/<owner>/google-chat-cli/releases/download/v<version>/gchat-aarch64-apple-darwin.tar.gz"
      sha256 "<arm64_sha256>"
    else
      url "https://github.com/<owner>/google-chat-cli/releases/download/v<version>/gchat-x86_64-apple-darwin.tar.gz"
      sha256 "<x86_64_sha256>"
    end
  end

  def install
    bin.install "gchat"
  end

  test do
    output = shell_output("#{bin}/gchat --version")
    assert_match '"ok": true', output
  end
end
